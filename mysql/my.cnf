# MySQL 8.0 — WooCommerce-tuned configuration
# Managed by Ansible — placed at /etc/mysql/mysql.conf.d/woocommerce.cnf
# Sizes assume a 4 GB RAM VPS (CX21). Adjust for larger nodes.

[mysqld]

# ─────────────────────────────────────────
# Network — bind to localhost only
# ─────────────────────────────────────────
bind-address            = 127.0.0.1
port                    = 3306

# ─────────────────────────────────────────
# InnoDB — primary WooCommerce storage engine
# ─────────────────────────────────────────
# Buffer pool: largest single tuning lever.
# Rule of thumb: 70% of available RAM when MySQL is the only major service.
# On a 4 GB box (after Nginx/PHP/Redis overhead), 1.5–2 GB is safe.
innodb_buffer_pool_size = 1536M

# Single buffer pool instance is fine under ~1 GB; use 4 for larger pools
innodb_buffer_pool_instances = 2

# Flush neighbors disabled on SSD — no benefit, adds write amplification
innodb_flush_neighbors  = 0

# O_DIRECT bypasses OS page cache for large buffer pools (avoids double-caching)
innodb_flush_method     = O_DIRECT

# Log file size: larger = fewer checkpoints, better write throughput
innodb_log_file_size    = 256M
innodb_log_buffer_size  = 16M

# WooCommerce does lots of small writes (orders, stock, sessions)
innodb_flush_log_at_trx_commit = 1   # 1 = full ACID (required for payment data)

# File-per-table: easier backup, recovery, and space reclaim after deletes
innodb_file_per_table   = ON

# ─────────────────────────────────────────
# Connections
# ─────────────────────────────────────────
max_connections         = 150    # PHP-FPM workers × headroom; too high = OOM risk
wait_timeout            = 300
interactive_timeout     = 300
connect_timeout         = 10

# ─────────────────────────────────────────
# Query cache — DISABLED in MySQL 8.0 (removed)
# Use Redis object cache at the WordPress layer instead
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# Slow query log — identify WooCommerce queries to optimize
# ─────────────────────────────────────────
slow_query_log          = ON
slow_query_log_file     = /var/log/mysql/slow.log
long_query_time         = 2      # seconds; lower to 0.5 after baseline
log_queries_not_using_indexes = ON

# ─────────────────────────────────────────
# Temporary tables — WooCommerce reports use large aggregations
# ─────────────────────────────────────────
tmp_table_size          = 64M
max_heap_table_size     = 64M

# ─────────────────────────────────────────
# Character set — WooCommerce requires utf8mb4 for emoji product names
# ─────────────────────────────────────────
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci

# ─────────────────────────────────────────
# Binary logging — required for point-in-time recovery
# ─────────────────────────────────────────
log_bin                 = /var/log/mysql/mysql-bin.log
binlog_expire_logs_seconds = 604800   # 7 days
max_binlog_size         = 100M
binlog_format           = ROW

# ─────────────────────────────────────────
# Table open cache
# ─────────────────────────────────────────
table_open_cache        = 2000
table_definition_cache  = 1400

[client]
default-character-set   = utf8mb4
