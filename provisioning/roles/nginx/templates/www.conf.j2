; PHP-FPM pool for WordPress/WooCommerce
; Managed by Ansible — do not edit by hand

[www]
user = www-data
group = www-data

listen = /run/php/php{{ php_version }}-fpm.sock
listen.owner = www-data
listen.group = www-data
listen.mode = 0660

; Dynamic process manager — scales between min/max spare based on load
pm = dynamic
pm.max_children = {{ php_fpm_pm_max_children }}
pm.start_servers = {{ php_fpm_pm_start_servers }}
pm.min_spare_servers = {{ php_fpm_pm_min_spare_servers }}
pm.max_spare_servers = {{ php_fpm_pm_max_spare_servers }}
pm.max_requests = 500

; Log slow requests (> 10s) for profiling
slowlog = /var/log/php-fpm/slow.log
request_slowlog_timeout = 10s

; Status endpoint — blocked at Nginx except for localhost
pm.status_path = /fpm-status

; Pass real client IP from Nginx
env[REMOTE_ADDR] = $REMOTE_ADDR
